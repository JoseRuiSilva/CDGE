# ─────────────────────────────────────────────────────────────────────────────
# Auto Escala — .gitignore
# CDGE | Universidade do Minho | 2025-2026
# ─────────────────────────────────────────────────────────────────────────────

# ── Credenciais e configuração local ────────────────────────────────────────
.env
*.env
!.env.example

# ── Dados gerados (não versionar CSVs/JSON de centenas de MB) ───────────────
data/sources/
data/watermark.json

# ── Delta Lake (gerado pelo pipeline — pode ser reconstruído) ───────────────
data_lake/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Ambientes virtuais ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Sistema operativo ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs e temporários ───────────────────────────────────────────────────────
*.log
*.tmp
*.bak
logs/
tmp/

# ── Docker volumes (se montados localmente) ──────────────────────────────────
postgres_data/
pgadmin_data/

# ── Relatório (PDFs compilados, não o fonte) ─────────────────────────────────
relatorio/*.pdf
relatorio/*.aux
relatorio/*.out
relatorio/*.toc

# -- Ficheiros adicionais para uso próprio -----------------------------------
extras/
