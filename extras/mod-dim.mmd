erDiagram
    %% Tabelas de Dimensão
    dim_veiculo {
        string id_veiculo PK
        string marca
        string modelo
        int ano_viatura
        string combustivel
        string segmento
    }

    dim_stand {
        string id_stand PK
        string nome_stand
        string cidade
        string regiao
    }

    dim_tempo {
        string id_tempo PK
        date data
        string semana
        string mes
        string trimestre
        int ano
    }

    %% Tabelas de Factos
    fact_inventario {
        string id_viatura PK
        string id_veiculo FK
        string id_stand FK
        string id_tempo_entrada FK "Role-playing (Entrada)"
        string id_tempo_venda FK "Role-playing (Venda, pode ser NULL)"
        int quilometragem
        float preco_aquisicao
        float preco_venda
        int dias_em_stock
        float margem
    }

    fact_tendencias {
        string id_tendencia PK
        string id_veiculo FK
        string id_tempo FK
        string regiao
        int valor_interesse
        float taxa_crescimento_semanal
        float media_movel_4_semanas
    }

    %% Relacionamentos do Star Schema
    dim_veiculo ||--o{ fact_inventario : "filtra (1:N)"
    dim_stand ||--o{ fact_inventario : "filtra (1:N)"
    dim_tempo ||--o{ fact_inventario : "filtra por entrada (1:N)"
    dim_tempo ||--o{ fact_inventario : "filtra por venda (1:N)"

    dim_veiculo ||--o{ fact_tendencias : "filtra (1:N)"
    dim_tempo ||--o{ fact_tendencias : "filtra (1:N)"